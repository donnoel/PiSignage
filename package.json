{
  "name": "beam",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "dashboard",
    "device-agent",
    "player"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "dev:dashboard": "npm --workspace dashboard run dev",
    "dev:player": "npm --workspace player run dev",
    "serve:player": "node device/pi/bin/pisignage-serve-player.mjs",
    "agent:heartbeat": "npm --workspace device-agent run heartbeat",
    "agent:loop": "npm --workspace device-agent run loop",
    "simulate:failures": "node scripts/local-failure-smoke.mjs",
    "test:schedule": "node scripts/schedule-evaluation-smoke.mjs",
    "test:workspace-auth": "node scripts/workspace-auth-smoke.mjs",
    "test:cloud-inventory": "node scripts/cloud-inventory-assignment-smoke.mjs",
    "test:aws-cost-hot-path": "node scripts/aws-cost-hot-path-smoke.mjs",
    "test:device-agent-cache": "npm --workspace device-agent run build && node scripts/device-agent-cache-sync-smoke.mjs",
    "test:release-state": "node scripts/release-state-smoke.mjs",
    "test:dashboard-css": "node scripts/dashboard-css-smoke.mjs",
    "test:bad-upload": "node scripts/bad-media-upload-smoke.mjs",
    "test:bad-playback": "node scripts/bad-media-playback-smoke.mjs",
    "test:vlc-boundary-handoff": "node scripts/vlc-boundary-handoff-smoke.mjs",
    "test:vlc-continuous-handoff": "node scripts/vlc-continuous-handoff-smoke.mjs",
    "test:vlc-continuous-immediate-handoff": "node scripts/vlc-continuous-immediate-handoff-smoke.mjs",
    "test:vlc-continuous-exit": "node scripts/vlc-continuous-exit-backoff-smoke.mjs",
    "test:vlc-playback-proof": "node scripts/vlc-playback-proof-smoke.mjs",
    "test:release-hardening": "npm run typecheck && npm run test:cloud-inventory && npm run test:device-agent-cache && npm run test:release-state && npm run test:schedule && npm run test:vlc-boundary-handoff && npm run test:vlc-continuous-handoff && npm run test:vlc-continuous-immediate-handoff && npm run test:vlc-continuous-exit && npm run test:vlc-playback-proof && npm run simulate:failures",
    "drill:pi": "node scripts/pi-failure-drills.mjs",
    "check:rc-parity": "node scripts/beam-rc-parity-check.mjs",
    "generate:still-presets": "node scripts/generate-still-video-presets.mjs"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
